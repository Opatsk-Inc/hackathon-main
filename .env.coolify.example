# ─── Paste into Coolify → App → Environment Variables ───────────────────────
# Copy the block below, edit values, paste into Coolify's bulk env editor.
# Domains are NOT set here — enter them in Coolify's "Domains" field per service
# (backend + frontend). Coolify injects them as SERVICE_FQDN_BACKEND_1488 and
# SERVICE_FQDN_FRONTEND_80 automatically.

# ─── Postgres ────────────────────────────────────────────────────────────────
POSTGRES_USER=mainuser
POSTGRES_PASSWORD=452b2554bb4c63d311758db68fc7fe1f
POSTGRES_DB=maindb

# ─── Backend (NestJS) ────────────────────────────────────────────────────────
# Minimum 32 chars. Generate:  openssl rand -hex 32
JWT_SECRET=d02458c226eaee6ed41a1dd5884f9828c1d1c443cfec091fe15bfed9ad848ede
EXPIRATION_TIME=7d

# Deploy-time behavior:
#   true  → every deploy wipes the DB and re-applies migrations (+ seed if present)
#   false → only applies pending migrations; existing data is preserved
RESET_DB_ON_DEPLOY=true
