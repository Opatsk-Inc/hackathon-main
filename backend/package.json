{
  "name": "nest-hackathon-backend",
  "version": "0.1.0",
  "description": "Hackathon backend project for NestJS.",
  "author": "Dan",
  "scripts": {
    "build": "rimraf dist && tsc -p tsconfig.build.json",
    "clean": "rimraf dist",
    "format": "prettier --write \"src/**/*.ts\" ",
    "start": "dotenv -e .env -- nest start",
    "start:dev": "dotenv -e .env -- nest start --watch",
    "start:debug": "dotenv -e .env -- nest start --debug --watch",
    "lint": "eslint \"src/**/*.ts\" --fix",
    "migrate:dev": "dotenv -e .env -- prisma migrate dev --preview-feature",
    "migrate:dev:create": "dotenv -e .env -- prisma migrate dev --create-only --preview-feature",
    "migrate:dev:pull": "dotenv -e .env -- prisma db pull",
    "migrate:reset": "dotenv -e .env -- prisma migrate reset --preview-feature",
    "migrate:deploy:dev": "dotenv -e .env -- npx prisma migrate deploy --preview-feature",
    "migrate:status": "npx prisma migrate status --preview-feature",
    "migrate:resolve": "npx prisma migrate resolve --preview-feature",
    "prisma:studio": "npx prisma studio",
    "prisma:generate": "npx prisma generate",
    "prisma:generate:watch": "npx prisma generate --watch",
    "postinstall": "npm run prisma:generate"
  },
  "prisma": {
    "seed": "npx tsx prisma/seed.ts"
  },
  "lint-staged": {
    "*.{js,ts}": [
      "cross-env NODE_ENV=development eslint --cache"
    ],
    "{*.json,.{prettierrc}}": [
      "prettier --ignore-path .eslintignore --parser json --write"
    ],
    "*.{html,md,yml}": [
      "prettier --ignore-path .eslintignore --single-quote --write"
    ]
  },
  "dependencies": {
    "@nestjs/common": "^11.1.17",
    "@nestjs/config": "4.0.3",
    "@nestjs/core": "^11.1.17",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.17",
    "@nestjs/swagger": "^11.2.6",
    "@nestjs/throttler": "6.5.0",
    "@prisma/adapter-pg": "^7.6.0",
    "@prisma/client": "7.6.0",
    "@types/xlsx": "^0.0.35",
    "bcrypt": "^6.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "dotenv": "^17.4.2",
    "dotenv-cli": "11.0.0",
    "groq-sdk": "^1.1.2",
    "helmet": "^8.1.0",
    "localtunnel": "^2.0.2",
    "nanoid": "^5.1.7",
    "nodemailer": "^8.0.4",
    "papaparse": "^5.4.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.20.0",
    "prisma": "7.6.0",
    "reflect-metadata": "^0.2.2",
    "request-ip": "^3.3.0",
    "rimraf": "^6.1.3",
    "rxjs": "^7.8.2",
    "swagger-ui-express": "^5.0.1",
    "tsx": "^4.21.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@nestjs/cli": "^11.0.17",
    "@nestjs/schematics": "^11.0.10",
    "@types/bcrypt": "^6.0.0",
    "@types/express": "^5.0.6",
    "@types/multer": "^1.4.12",
    "@types/nanoid": "^3.0.0",
    "@types/node": "^25.6.0",
    "@types/nodemailer": "^7.0.11",
    "@types/papaparse": "^5.3.14",
    "@types/passport-jwt": "^4.0.1",
    "@types/pg": "^8.20.0",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "cross-env": "^10.1.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.5",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "source-map-support": "^0.5.21",
    "ts-loader": "^9.5.7",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.0.0"
  }
}
